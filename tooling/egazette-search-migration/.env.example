# =============================================================================
# SearchSG (destination)
# =============================================================================

# Base64-encoded API key used to obtain a bearer token from SearchSG.
# Same secret as the site-launch tool's SEARCHSG_API_KEY.
SEARCHSG_API_KEY=

# The SearchSG application/client id for the eGazette search app.
# This is the `applicationId` returned when the SearchSG client was bootstrapped.
SEARCHSG_CLIENT_ID=

# SearchSG admin API base. Leave as the default unless told otherwise.
SEARCHSG_BASE_URL=https://api.services.search.gov.sg/admin

# =============================================================================
# Ingestion tuning
# =============================================================================

# Documents per request. SearchSG accepts at most 500. Lower it if you hit limits.
BATCH_SIZE=500

# Upper bound on requests per second (one request == one batch). Tune to stay
# under SearchSG's rate limit. Start conservative.
MAX_REQUESTS_PER_SECOND=2

# Retries per batch on 429 / 5xx / token-expiry before the batch is dead-lettered.
MAX_RETRIES=5

# Set to "true" to run the ingest without sending anything to SearchSG. Validates
# parsing + transform + batching only.
DRY_RUN=false

# =============================================================================
# File paths (relative to this package directory)
# =============================================================================

# NDJSON file of source records (one JSON object per line). Produced by `export`,
# consumed by `ingest` and `verify`.
DOCUMENTS_FILE=./data/documents.ndjson

# Resume checkpoint. Delete it to start ingestion from the beginning.
CHECKPOINT_FILE=./data/checkpoint.json

# Batches that fail after all retries are appended here as NDJSON. To retry only
# the failures: point DOCUMENTS_FILE at this file, use a fresh CHECKPOINT_FILE, re-run.
DEADLETTER_FILE=./data/deadletter.ndjson

# =============================================================================
# Algolia (source) - only required for the `export` command
# =============================================================================

ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_INDEX_NAME=
