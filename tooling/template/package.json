{
  "name": "isomer-base-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:local": "rm -rf .next && curl https://raw.githubusercontent.com/opengovsg/isomer/main/tooling/build/scripts/preBuild.sh | bash && pnpm run build",
    "build:template": "next build",
    "clean": "git clean -xdf .next .turbo node_modules out",
    "dev": "PORT=3001 next",
    "format": "oxfmt --check . --ignore-path ../../.gitignore",
    "format:fix": "oxfmt --write . --ignore-path ../../.gitignore",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "start": "next start",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@opengovsg/isomer-components": "workspace:*",
    "isomorphic-dompurify": "catalog:",
    "jsdom": "catalog:",
    "next": "catalog:",
    "postcss": "catalog:",
    "postcss-preset-env": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "tailwindcss": "catalog:",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@isomer/oxlint-config": "workspace:*",
    "@isomer/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@typescript/native-preview": "catalog:"
  }
}
