{
  "name": "isomer-base-template",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:local": "rm -rf .next && curl https://raw.githubusercontent.com/opengovsg/isomer/main/tooling/build/scripts/preBuild.sh | bash && npm run build",
    "build:template": "next build",
    "clean": "git clean -xdf .next .turbo node_modules out",
    "dev": "PORT=3001 next",
    "format": "oxfmt --check . --ignore-path ../../.gitignore",
    "format:fix": "oxfmt --write . --ignore-path ../../.gitignore",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "start": "next start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opengovsg/isomer-components": "*",
    "next": "^15.5.15",
    "postcss": "^8.4.39",
    "postcss-preset-env": "^10.0.8",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.9.2"
  },
  "devDependencies": {
    "@isomer/oxlint-config": "*",
    "@isomer/tsconfig": "*",
    "@types/node": "^22.15.21"
  }
}
