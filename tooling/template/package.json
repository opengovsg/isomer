{
  "name": "isomer-base-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:local": "rm -rf dist && curl https://raw.githubusercontent.com/opengovsg/isomer/main/tooling/build/scripts/preBuild.sh | bash && pnpm run build:template",
    "build:template": "waku build",
    "clean": "git clean -xdf out .turbo node_modules",
    "dev": "waku dev",
    "format": "oxfmt --check . --ignore-path ../../.gitignore",
    "format:fix": "oxfmt --write . --ignore-path ../../.gitignore",
    "generate:robots": "tsx scripts/generate-robots.ts",
    "generate:sitemap": "tsx scripts/generate-sitemap.ts",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "start": "waku start",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@fontsource-variable/inter": "catalog:",
    "@opengovsg/isomer-components": "workspace:*",
    "isomorphic-dompurify": "catalog:",
    "jsdom": "catalog:",
    "postcss": "catalog:",
    "postcss-preset-env": "catalog:",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "waku": "catalog:"
  },
  "devDependencies": {
    "@isomer/oxlint-config": "workspace:*",
    "@isomer/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@typescript/native-preview": "catalog:",
    "tsx": "catalog:"
  }
}
