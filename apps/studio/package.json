{
  "name": "isomer-studio",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "SKIP_ENV_VALIDATION=true next build",
    "build-storybook": "storybook build",
    "build:preview-tw": "NODE_ENV=production pnpm exec tailwindcss build -i src/styles/tailwind.css -o public/assets/css/preview-tw.css && oxfmt --write public/assets/css/preview-tw.css",
    "build:theme": "pnpm exec chakra-cli tokens src/theme/index.ts",
    "clean": "git clean -xdf .next .turbo node_modules build",
    "db:connect": "bash ./scripts/connectRds.sh prod",
    "db:connect:staging": "bash ./scripts/connectRds.sh staging",
    "db:connect:uat": "bash ./scripts/connectRds.sh uat",
    "db:connect:vapt": "bash ./scripts/connectRds.sh vapt",
    "db:push": "prisma db push",
    "db:reset": "prisma migrate reset",
    "db:seed": "prisma db seed",
    "db:sleep": "sleep 3",
    "dev": "next dev",
    "dev:e2e": "dotenv -e .env.test start-server-and-test dev http://127.0.0.1:3000 test:e2e",
    "format": "oxfmt --check . --ignore-path ../../.gitignore",
    "format:fix": "oxfmt --write . --ignore-path ../../.gitignore",
    "generate": "prisma generate && tsx prisma/generate.cts && oxlint --fix prisma/generated && pnpm exec oxfmt --write prisma/generated",
    "generate:jwks": "tsx scripts/generateJwks.ts",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "migrate": "prisma migrate deploy",
    "migrate:custom": "tsx prisma/custom/install.ts",
    "migrate:dev": "prisma migrate dev",
    "migrate:staging": "source .ssh/.env.staging && pnpm exec prisma migrate deploy",
    "migrate:uat": "source .ssh/.env.uat && pnpm exec prisma migrate deploy",
    "predev": "run-s migrate",
    "prestart": "pnpm run migrate",
    "services:setup": "docker compose -f \"docker-compose.yml\" up -d --wait",
    "setup": "run-s --print-label services:setup db:sleep migrate:dev db:seed",
    "setup:test": "run-s --print-label services:setup db:sleep migrate generate",
    "start": "next start",
    "storybook": "storybook dev -p 6007",
    "teardown": "docker compose down",
    "test": "run-s test:*",
    "test-ci:e2e": "dotenv -e .env.test start-server-and-test start http://127.0.0.1:3000 test:e2e",
    "test-ci:unit": "dotenv -e .env.test vitest run -- --coverage",
    "test-dev": "start-server-and-test dev http://127.0.0.1:3000 test",
    "test-dev:unit": "dotenv -e .env.test vitest",
    "test:e2e": "dotenv -e .env.test pnpm exec playwright test",
    "test:load:build": "webpack-cli --config tests/load/webpack.config.cjs",
    "test:unit": "dotenv -e .env.test vitest run",
    "test:watch": "dotenv -e .env.test pnpm exec vitest watch",
    "typecheck": "tsc --noEmit"
  },
