{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "db:seed": {},
    "test:watch": {},
    "test:unit": {
      "dependsOn": ["generate"]
    },
    "test-ci:unit": {},
    "test-ci:e2e": {
      "outputs": ["e2e/test-results/**"]
    },
    "test:e2e": {
      "outputs": ["e2e/test-results/**"]
    },
    "generate": {
      "dependsOn": ["@opengovsg/isomer-components#build"],
      "inputs": ["prisma/schema.prisma"],
      "cache": false
    },
    "build:preview-tw": {
      "dependsOn": ["@opengovsg/isomer-components#build"],
      "outputs": ["public/assets/css/preview-tw.css"]
    },
    "build:oui-css": {
      "outputs": ["public/assets/css/oui.css"]
    },
    "format": {
      "dependsOn": ["generate"]
    },
    "lint": {
      "dependsOn": ["generate"]
    },
    "typecheck": {
      "dependsOn": ["generate"]
    },
    "dev": {
      "dependsOn": ["services:setup", "build:preview-tw", "build:oui-css"],
      "cache": false,
      "persistent": true
    },
    "storybook": {
      "dependsOn": ["build:preview-tw", "build:oui-css"],
      "cache": false,
      "persistent": true
    },
    "build-storybook": {
      "dependsOn": ["build:preview-tw", "build:oui-css"]
    },
    "dev:e2e": {
      "dependsOn": ["services:setup"],
      "cache": false,
      "persistent": true
    },
    "build:theme": {},
    "build": {
      "dependsOn": [
        "@opengovsg/isomer-components#build",
        "generate",
        "build:theme",
        "build:preview-tw",
        "build:oui-css"
      ],
      "outputs": [".next/**", "!.next/cache/**"]
    }
  }
}
