{
  "compilerOptions": {
    "types": ["node", "vitest/globals"],
    "declaration": true,
    "rootDir": "src",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "~/*": ["./src/*"]
    },
    "lib": ["es2021"]
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
