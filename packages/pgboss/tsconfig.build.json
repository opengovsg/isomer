{
  "extends": "./tsconfig",
  "compilerOptions": {
    "target": "es2021",
    "outDir": "dist/cjs",
    "module": "commonjs",
    "declaration": true
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/__tests__/**",
    "src/**/__test__/**"
  ]
}
