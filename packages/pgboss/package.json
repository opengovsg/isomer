{
  "name": "@isomer/pgboss",
  "version": "0.0.0",
  "private": true,
  "files": [
    "src"
  ],
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc --noEmit",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "db:sleep": "sleep 3",
    "format": "oxfmt --check . --ignore-path ../../.gitignore",
    "format:fix": "oxfmt --write . --ignore-path ../../.gitignore",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "services:setup": "docker compose -f \"docker-compose.yml\" up -d --wait",
    "setup:test": "run-s --print-label services:setup db:sleep",
    "test": "dotenv -e .env.test npx vitest run",
    "test:watch": "dotenv -e .env.test npx vitest watch",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@isomer/logging": "*",
    "pg-boss": "^12.3.0"
  },
  "devDependencies": {
    "@isomer/oxlint-config": "*",
    "@isomer/tsconfig": "*",
    "@types/node": "^22.15.21",
    "@vitest/coverage-istanbul": "^2.1.2",
    "eslint": "^9.10.0",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.2",
    "vitest": "^2.1.1"
  }
}
