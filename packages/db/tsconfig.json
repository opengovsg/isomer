{
  "compilerOptions": {
    "types": ["node"],
    "noEmit": true,
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "lib": ["es2021"]
  },
  "include": [
    "src/**/*.ts",
    "prisma/**/*.ts",
    "prisma/**/*.cts",
    "prisma.config.ts"
  ],
  "exclude": ["node_modules"]
}
