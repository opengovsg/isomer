{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // CJS emit pinned to node resolution; base uses bundler for typecheck against Storybook 10's package exports.
    "module": "commonjs",
    "moduleResolution": "node"
  },
  "exclude": [
    ".storybook",
    "node_modules",
    "build",
    "src/**/*.stories.tsx",
    "src/**/*.test.tsx"
  ]
}
