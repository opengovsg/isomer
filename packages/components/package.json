{
  "name": "@opengovsg/isomer-components",
  "version": "0.0.13",
  "description": "Isomer component library",
  "license": "ISC",
  "author": {
    "name": "Isomer Team"
  },
  "files": [
    "dist/esm",
    "!**/*.spec.*",
    "!**/*.stories.*",
    "!**/*.json",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "default": "./dist/esm/index.js"
    },
    "./templates/next": {
      "import": "./dist/esm/templates/next/index.js",
      "default": "./dist/esm/templates/next/index.js"
    },
    "./build-utils": {
      "import": "./dist/esm/build-utils/index.js",
      "default": "./dist/esm/build-utils/index.js"
    }
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com/isomerpages"
  },
  "scripts": {
    "build": "run-p build:* && pnpm pack",
    "build-storybook": "storybook build",
    "build:module": "tsc -p tsconfig.module.build.json && tsc-alias -p tsconfig.module.build.json",
    "chromatic": "pnpm exec chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "clean": "git clean -xdf .turbo node_modules dist",
    "dev": "tsc -w",
    "format": "oxfmt --check . --ignore-path ../../.gitignore",
    "format:fix": "oxfmt --write . --ignore-path ../../.gitignore",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "prebuild": "rimraf dist",
    "storybook": "storybook dev -p 6006",
    "supportedBrowsers": "echo \"export default $(browserslist-useragent-regexp --allowHigherVersions)\" > src/utils/supportedBrowsers.ts",
    "test": "run-s test:*",
    "test-ci:unit": "dotenv -e .env.test vitest run --coverage",
    "test:unit": "dotenv -e .env.test vitest run",
    "test:watch": "pnpm exec vitest watch",
    "typecheck": "tsgo --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@headlessui/react": "catalog:",
    "@isomer/validators": "workspace:*",
    "@react-aria/button": "catalog:react-aria",
    "@react-aria/checkbox": "catalog:react-aria",
    "@react-aria/focus": "catalog:react-aria",
    "@react-aria/interactions": "catalog:react-aria",
    "@react-aria/textfield": "catalog:react-aria",
    "@react-aria/utils": "catalog:react-aria",
    "@react-stately/checkbox": "catalog:react-aria",
    "@react-stately/toggle": "catalog:react-aria",
    "@sinclair/typebox": "catalog:",
    "algoliasearch": "catalog:",
    "date-fns": "catalog:",
    "interweave": "catalog:",
    "interweave-ssr": "catalog:",
    "isomorphic-dompurify": "catalog:",
    "js-md5": "catalog:",
    "lodash-es": "catalog:",
    "minisearch": "catalog:",
    "react-icons": "catalog:",
    "react-instantsearch": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwind-variants": "catalog:",
    "tailwindcss-react-aria-components": "catalog:",
    "type-fest": "catalog:",
    "usehooks-ts": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@isomer/oxlint-config": "workspace:*",
    "@isomer/storybook-config": "workspace:*",
    "@isomer/tsconfig": "workspace:*",
    "@storybook/addon-a11y": "catalog:storybook",
    "@storybook/addon-docs": "catalog:storybook",
    "@storybook/addon-links": "catalog:storybook",
    "@storybook/addon-themes": "catalog:storybook",
    "@storybook/react-vite": "catalog:storybook",
    "@testing-library/react": "catalog:",
    "@types/lodash-es": "catalog:",
    "@types/lunr": "catalog:",
    "@types/react": "catalog:react",
    "@types/react-dom": "catalog:react",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-react": "catalog:vitest",
    "@vitest/browser-playwright": "catalog:vitest",
    "@vitest/coverage-istanbul": "catalog:vitest",
    "bootstrap-icons": "catalog:",
    "browserslist-useragent-regexp": "catalog:",
    "chromatic": "catalog:",
    "eslint-plugin-storybook": "catalog:storybook",
    "mockdate": "catalog:",
    "msw": "catalog:",
    "msw-storybook-addon": "catalog:",
    "npm-run-all2": "catalog:",
    "playwright": "catalog:playwright",
    "postcss": "catalog:",
    "postcss-preset-env": "catalog:",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "rimraf": "catalog:",
    "storybook": "catalog:storybook",
    "storybook-addon-pseudo-states": "catalog:storybook",
    "tailwindcss": "catalog:",
    "tsc-alias": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:vitest",
    "vitest": "catalog:vitest"
  },
  "peerDependencies": {
    "react": "catalog:react",
    "react-dom": "catalog:react"
  },
  "browserslist": [
    "defaults",
    "chrome >= 64, edge >= 79, firefox >= 67, opera >= 51, safari >= 12",
    "not dead"
  ],
  "msw": {
    "workerDirectory": "public"
  }
}
