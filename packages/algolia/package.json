{
  "name": "@isomer/algolia",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "clean": "git clean -xdf .cache .turbo node_modules",
    "format": "oxfmt --check . --ignore-path ../../.gitignore",
    "format:fix": "oxfmt --write . --ignore-path ../../.gitignore",
    "lint": "oxlint --type-aware .",
    "lint:fix": "oxlint --type-aware --fix .",
    "test": "pnpm test:unit",
    "test-ci:unit": "vitest run",
    "test:unit": "vitest run",
    "test:watch": "vitest watch",
    "typecheck": "tsgo"
  },
  "dependencies": {
    "algoliasearch": "catalog:",
    "pdfreader": "^3.0.8",
    "vitest": "catalog:vitest"
  },
  "devDependencies": {
    "@isomer/oxlint-config": "workspace:*",
    "@isomer/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-istanbul": "catalog:vitest",
    "npm-run-all2": "catalog:",
    "typescript": "catalog:"
  }
}
